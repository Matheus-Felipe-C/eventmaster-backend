APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

SUPABASE_STORAGE_KEY=
SUPABASE_STORAGE_SECRET=
SUPABASE_STORAGE_REGION=us-east-1
SUPABASE_STORAGE_BUCKET=
SUPABASE_STORAGE_ENDPOINT=
SUPABASE_STORAGE_URL=
SUPABASE_STORAGE_PATH_STYLE=true

MERCADO_PAGO_ACCESS_TOKEN=
# Use "local" for sandbox on localhost (Mercado Pago SDK). Default: server
# MERCADO_PAGO_RUNTIME=local
# Checkout Pro return URLs (frontend)
# MERCADO_PAGO_BACK_SUCCESS_URL=https://your-frontend.example/checkout/success
# MERCADO_PAGO_BACK_FAILURE_URL=https://your-frontend.example/checkout/failure
# MERCADO_PAGO_BACK_PENDING_URL=https://your-frontend.example/checkout/pending
# Public URL for webhooks (defaults to {APP_URL}/api/webhooks/mercado-pago)
# MERCADO_PAGO_NOTIFICATION_URL=https://your-api.example/api/webhooks/mercado-pago
# MERCADO_PAGO_STATEMENT_DESCRIPTOR=EVENTMASTER

VITE_APP_NAME="${APP_NAME}"

# CORS: comma-separated list of frontend origins when API is on a different domain (e.g. Coolify)
# Example: https://myapp.mydomain.com,https://www.mydomain.com
# Leave empty to allow any origin (not recommended with credentials).
# CORS_ORIGINS=
# CORS_CREDENTIALS=true

# Sanctum: add your frontend domain(s) for stateful auth (same as CORS in most cases)
# SANCTUM_STATEFUL_DOMAINS=myapp.mydomain.com,www.mydomain.com

# Default admin user created by AdminUserSeeder
# ADMIN_NAME=Admin
# ADMIN_CPF=000.000.000-00
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=changeme
